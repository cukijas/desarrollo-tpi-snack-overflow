# Rename this file to .env for local development.
# Never commit .env — it is gitignored.

# PostgreSQL — matches docker-compose defaults
DB_HOST=localhost
DB_PORT=5432
DB_USER=snack_user
DB_PASSWORD=snack_password
DB_NAME=snack_overflow
DB_SSL=false

# Redis — matches docker-compose defaults
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change_me_to_a_random_256_bit_secret

# SMTP (for password recovery emails)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@snackoverflow.local

# Application
APP_BASE_URL=http://localhost:3001
NODE_ENV=development
PORT=3000
